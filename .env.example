# =============================================================================
# Pantha — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# =============================================================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://pantha:pantha@localhost:5432/pantha?schema=public"

# --- NextAuth ---
# A random secret used to encrypt session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# The canonical URL of your Pantha instance
NEXTAUTH_URL="http://localhost:3000"

# --- AI Providers (optional, users can also set these in the UI) ---
# OpenAI
OPENAI_API_KEY=""

# Anthropic
ANTHROPIC_API_KEY=""

# Groq
GROQ_API_KEY=""

# Ollama (self-hosted)
OLLAMA_BASE_URL="http://localhost:11434"
